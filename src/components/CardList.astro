---
interface Item {
  text: string;
  href: string;
  description?: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

{items.map((item, index) => (
  <>
    <div class="card-list__item" role="listitem" style={`position: relative; padding: ${index === 0 ? '0' : '20px'} 40px 20px 0;`}>
      <h2 class="card-list__heading govuk-heading-s">
        <a class="govuk-link card-list__link" href={item.href}>{item.text}</a>
      </h2>
      {item.description && (
        <p class="govuk-body card-list__description">{item.description}</p>
      )}
    </div>
    {index < items.length - 1 && <hr class="card-list__divider" />}
  </>
))}

<style>
  .card-list__item {
    position: relative;
  }

  .card-list__item::after {
    content: '';
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
    width: 10px;
    height: 10px;
    border-top: 2px solid #003476;
    border-right: 2px solid #003476;
    pointer-events: none;
  }

  .card-list__heading {
    margin-bottom: 4px;
  }

  .card-list__link::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .card-list__description {
    margin: 0;
    color: #505a5f;
  }

  .card-list__divider {
    margin: 0;
    border: none;
    border-top: 1px solid var(--govgr-secondary);
    opacity: 0.6;
  }
</style>
