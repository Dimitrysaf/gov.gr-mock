---
import Layout from '../layouts/Layout.astro';

interface Topic {
  value: string;
  label: string;
}

interface Item {
  title: string;
  type: string;
  organisation: string;
  date: string;
  href: string;
  topic: string;
  description?: string;
}

interface RadioFilter {
  allLabel: string;
  options: string[];
}

interface Props {
  title: string;
  breadcrumbs: Array<{ text: string; href?: string }>;
  topics: Topic[];
  radioFilter?: RadioFilter;
  typeFilterLabel?: string;
  typeFilters?: string[];
  items: Item[];
}

const {
  title,
  breadcrumbs,
  topics,
  radioFilter,
  typeFilterLabel = 'Τύπος',
  typeFilters,
  items,
} = Astro.props;

function formatDate(dateStr: string) {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('el-GR', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Layout title={`${title} – gov.gr`} breadcrumbs={breadcrumbs}>
  <div class="govuk-width-container">

    <div class="govuk-grid-row govuk-!-margin-bottom-2">
      <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-2">{title}</h1>
      </div>
    </div>

    <div class="govuk-grid-row">

      <!-- ── Filters ── -->
      <div class="govuk-grid-column-one-third">

        <div class="gem-c-search gem-c-search--on-white gem-c-search--separate-label govuk-!-margin-bottom-6" role="search">
          <label for="finder-keyword-search" class="gem-c-search__label">
            Αναζήτηση <span class="govuk-visually-hidden">{title}</span>
          </label>
          <div class="gem-c-search__item-wrapper">
            <div class="gem-c-search__input-wrapper">
              <input
                class="gem-c-search__input gem-c-search__input--on-white"
                id="finder-keyword-search"
                type="search"
                autocorrect="off"
                autocapitalize="off"
              />
            </div>
            <div class="gem-c-search__submit-wrapper">
              <button class="gem-c-search__submit" type="button" aria-label="Αναζήτηση">
                <svg class="gem-c-search__icon" width="27" height="27" viewBox="0 0 27 27" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                  <circle cx="12.0161" cy="11.0161" r="8.51613" stroke="currentColor" stroke-width="3"></circle>
                  <line x1="17.8668" y1="17.3587" x2="26.4475" y2="25.9393" stroke="currentColor" stroke-width="3"></line>
                </svg>
              </button>
            </div>
          </div>
        </div>

        {radioFilter && (
          <div class="govuk-form-group govuk-!-margin-bottom-6">
            <div class="govuk-radios govuk-radios--small">
              <div class="govuk-radios__item">
                <input class="govuk-radios__input finder-radio" id="finder-radio-all" type="radio" name="finder-type-radio" value="" checked />
                <label class="govuk-label govuk-radios__label" for="finder-radio-all">{radioFilter.allLabel}</label>
              </div>
              {radioFilter.options.map((opt, i) => (
                <div class="govuk-radios__item">
                  <input class="govuk-radios__input finder-radio" id={`finder-radio-${i}`} type="radio" name="finder-type-radio" value={opt} />
                  <label class="govuk-label govuk-radios__label" for={`finder-radio-${i}`}>{opt}</label>
                </div>
              ))}
            </div>
          </div>
        )}

        <details class="govuk-details govuk-!-margin-bottom-0">
          <summary class="govuk-details__summary">
            <span class="govuk-details__summary-text">Θέμα</span>
          </summary>
          <div class="govuk-details__text">
            <div class="govuk-form-group govuk-!-margin-bottom-2">
              <label class="govuk-label" for="finder-topic-select">Θέμα</label>
              <select class="govuk-select" id="finder-topic-select" style="width:100%">
                <option value="">Όλα τα θέματα</option>
                {topics.map(t => (
                  <option value={t.value}>{t.label}</option>
                ))}
              </select>
            </div>
          </div>
        </details>

        {typeFilters && typeFilters.length > 0 && (
          <details class="govuk-details govuk-!-margin-bottom-0 govuk-!-margin-top-4">
            <summary class="govuk-details__summary">
              <span class="govuk-details__summary-text">{typeFilterLabel}</span>
            </summary>
            <div class="govuk-details__text">
              <div class="govuk-form-group govuk-checkboxes govuk-checkboxes--small govuk-!-margin-bottom-2">
                {typeFilters.map((type, i) => (
                  <div class="govuk-checkboxes__item">
                    <input class="govuk-checkboxes__input finder-type-check" id={`finder-type-${i}`} type="checkbox" value={type} />
                    <label class="govuk-label govuk-checkboxes__label" for={`finder-type-${i}`}>{type}</label>
                  </div>
                ))}
              </div>
            </div>
          </details>
        )}

      </div>

      <!-- ── Results ── -->
      <div class="govuk-grid-column-two-thirds">

        <p class="govuk-body-s govuk-hint govuk-!-margin-bottom-4" aria-live="polite">
          <span id="finder-results-count">{items.length}</span> αποτελέσματα
        </p>

        <ul class="finder-results-list" id="finder-results">
          {items.map(item => (
            <li
              class="finder-results-list__item"
              data-topic={item.topic}
              data-type={item.type}
              data-search={[item.title, item.organisation, item.description ?? ''].join(' ').toLowerCase()}
            >
              <h2 class="govuk-heading-s govuk-!-margin-bottom-1">
                <a class="govuk-link" href={item.href}>{item.title}</a>
              </h2>
              <p class="govuk-body-s govuk-hint govuk-!-margin-bottom-1">
                {item.type}
                {' · '}
                {item.organisation}
                {' · '}
                <time datetime={item.date}>{formatDate(item.date)}</time>
              </p>
              {item.description && (
                <p class="govuk-body-s govuk-!-margin-bottom-0">{item.description}</p>
              )}
            </li>
          ))}
        </ul>

        <p class="govuk-body" id="finder-no-results" hidden>
          Δεν βρέθηκαν αποτελέσματα. Δοκιμάστε διαφορετική αναζήτηση.
        </p>

      </div>
    </div>
  </div>
</Layout>

<script>
  function normalise(s: string) {
    return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
  }

  const keywordInput = document.getElementById('finder-keyword-search') as HTMLInputElement;
  const topicSelect  = document.getElementById('finder-topic-select') as HTMLSelectElement;
  const typeChecks   = document.querySelectorAll<HTMLInputElement>('.finder-type-check');
  const radioInputs  = document.querySelectorAll<HTMLInputElement>('.finder-radio');
  const countEl      = document.getElementById('finder-results-count')!;
  const noResults    = document.getElementById('finder-no-results') as HTMLElement;
  const items        = document.querySelectorAll<HTMLElement>('.finder-results-list__item');

  function applyFilters() {
    const kw    = normalise(keywordInput.value.trim());
    const topic = topicSelect.value;
    const types = Array.from(typeChecks).filter(c => c.checked).map(c => c.value);
    const radio = radioInputs.length > 0
      ? (document.querySelector<HTMLInputElement>('.finder-radio:checked')?.value ?? '')
      : null;

    let visible = 0;
    items.forEach(item => {
      const matchKw    = !kw    || normalise(item.dataset.search ?? '').includes(kw);
      const matchTopic = !topic || item.dataset.topic === topic;
      const matchType  = radio !== null
        ? (!radio || item.dataset.type === radio)
        : (types.length === 0 || types.includes(item.dataset.type ?? ''));
      const show = matchKw && matchTopic && matchType;
      item.hidden = !show;
      if (show) visible++;
    });

    countEl.textContent = String(visible);
    noResults.hidden = visible > 0;
  }

  keywordInput.addEventListener('input', applyFilters);
  topicSelect.addEventListener('change', applyFilters);
  typeChecks.forEach(c => c.addEventListener('change', applyFilters));
  radioInputs.forEach(r => r.addEventListener('change', applyFilters));
</script>

<style>
  .finder-results-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .finder-results-list__item {
    padding: 20px 0;
    border-top: 1px solid #b1b4b6;
  }

  .finder-results-list__item:last-child {
    border-bottom: 1px solid #b1b4b6;
  }

  .finder-results-list__item[hidden] {
    display: none;
  }
</style>
