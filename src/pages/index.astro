---
import Layout from '../layouts/Layout.astro';
import SearchForm from '../components/SearchForm.astro';
import CardList from '../components/CardList.astro';
import nav from '../data/navigation.json';
---

<Layout title="gov.gr – Η πύλη της ελληνικής κυβέρνησης">
  <div class="homepage-header">
    <div class="govuk-width-container">
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
          <div class="homepage-header__title-container">
            <h1 class="homepage-header__title">
              <span class="homepage-header__intro">Ο καλύτερος τρόπος για να βρείτε κυβερνητικές υπηρεσίες και πληροφορίες</span>
            </h1>
          </div>
          <SearchForm
            id="search-main"
            label="Αναζήτηση"
            placeholder="Αναζητήστε υπηρεσίες, πληροφορίες..."
          />
        </div>
      </div>
    </div>
  </div>

  <div class="govuk-width-container homepage-body">

    <div class="govuk-grid-row homepage-row--popular">
      <div class="govuk-grid-column-full">
        <h2 class="govuk-heading-l homepage-section__heading">Δημοφιλή στο gov.gr</h2>
        <ul class="homepage-most-viewed-list">
          {nav.popular.map(item => (
            <li class="homepage-most-viewed-list__item">
              <div class="gem-c-action-link gem-c-action-link--large">
                <span class="gem-c-action-link__icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" focusable="false" aria-hidden="true" viewBox="0 0 27 27" class="gem-c-action-link__svg">
                    <circle class="gem-c-action-link__icon__circle" cx="13.5" cy="13.5" r="13.5"></circle>
                    <g class="gem-c-action-link__icon__arrow">
                      <path d="m17.701 13.526-3.827-3.828L14.973 8.6l4.926 4.926-4.926 4.926-1.099-1.099 3.827-3.827Z"></path>
                      <path d="M8.363 12.749h9.762v1.554H8.363v-1.554Z"></path>
                    </g>
                  </svg>
                </span>
                <span class="gem-c-action-link__link-wrapper">
                  <a class="govuk-link gem-c-action-link__link" href={item.href}>{item.text}</a>
                </span>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="govuk-grid-row homepage-row">
      <div class="govuk-grid-column-two-thirds-from-desktop">
        <section>
          <h2 class="govuk-heading-l homepage-section__heading">Υπηρεσίες και πληροφορίες</h2>
          <CardList items={nav.services} />
        </section>
      </div>
      <div class="govuk-grid-column-one-third-from-desktop homepage-sidebar">
        <section>
          <h2 class="govuk-heading-l homepage-section__heading">Προτεινόμενα</h2>
          {nav.featured.map(item => (
            <div class="gem-c-image-card homepage-featured-card">
              <div class="gem-c-image-card__icon-wrapper" aria-hidden="true">
                <span class="material-symbols-sharp gem-c-image-card__icon">{item.icon}</span>
              </div>
              <div class="gem-c-image-card__text-wrapper">
                <h3 class="govuk-heading-s govuk-!-margin-bottom-1">
                  <a class="govuk-link" href={item.href}>{item.text}</a>
                </h3>
                <p class="govuk-body-s govuk-!-margin-bottom-0">{item.description}</p>
              </div>
            </div>
          ))}
        </section>
      </div>
    </div>

    <div class="govuk-grid-row homepage-row">
      <div class="govuk-grid-column-two-thirds-from-desktop">
        <section>
          <h2 class="govuk-heading-l homepage-section__heading">Δραστηριότητα</h2>
          <p class="govuk-body">Μάθετε τι κάνει η κυβέρνηση</p>
          <CardList items={nav.government} />
        </section>
      </div>
      <div class="govuk-grid-column-one-third-from-desktop homepage-sidebar">
        <section>
          <h2 class="govuk-heading-l homepage-section__heading">Περισσότερα στο gov.gr</h2>
          <ul class="homepage-most-active-list">
            {nav.more.map(item => (
              <li class="homepage-most-active-list__item">
                <a class="govuk-link" href={item.href}>{item.text}</a>
              </li>
            ))}
          </ul>
        </section>
      </div>
    </div>

  </div>
</Layout>

<style>
  .homepage-header {
    background-color: var(--govgr-brand);
    margin-top: -20px;
    padding: 30px 0 40px;
  }

  @media (min-width: 40.0625em) {
    .homepage-header {
      margin-top: -40px;
    }
  }

  .homepage-header__title-container {
    margin-bottom: 20px;
  }

  .homepage-header__title {
    margin: 0;
  }

  .homepage-header__intro {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.15;
    color: #ffffff;
    display: block;
  }

  @media (min-width: 48.0625em) {
    .homepage-header__intro {
      font-size: 3rem;
    }
  }

  .homepage-body {
    padding-bottom: 60px;
  }

  .homepage-row {
    border-top: 4px solid var(--govgr-brand);
    padding: 30px 0;
  }

  .homepage-section__heading {
    margin-top: 0;
  }

  .homepage-sidebar {
    margin-top: 30px;
  }

  @media (min-width: 48.0625em) {
    .homepage-sidebar {
      margin-top: 0;
    }
  }

  .homepage-featured-card {
    padding: 12px 0;
  }
</style>
